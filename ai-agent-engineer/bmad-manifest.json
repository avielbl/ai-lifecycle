{
  "name": "ai-agent-engineer",
  "description": "Training Specialist. Executes experiments and hyperparameter optimization against TECHSPEC contracts. Works across paradigms: epoch-based DL, boosting rounds, fit/predict loops.",
  "module-code": "ai",
  "has-memory": false,
  "capabilities": [
    {
      "name": "experiment",
      "menu-code": "AIEXP",
      "description": "Executes training/fit runs against the TECHSPEC.",
      "supports-headless": true,
      "phase-name": "6-experiment",
      "after": ["infra"],
      "before": ["analysis"],
      "is-required": true,
      "prompt": "experiment.md",
      "output-location": "{output_folder}/experiments"
    },
    {
      "name": "hparam",
      "menu-code": "AIHPO",
      "description": "Runs hyperparameter optimization (Optuna/W&B/Ray/ClearML).",
      "supports-headless": true,
      "phase-name": "7.5-hparam",
      "after": ["analysis"],
      "before": ["experiment"],
      "is-required": false,
      "prompt": "hparam.md",
      "output-location": "{output_folder}/experiments"
    }
  ]
}
