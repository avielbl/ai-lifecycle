{
  "name": "bmad-agent-dl-ai-developer",
  "description": "Variation of vanilla 'Developer'. Adapts models to constraints, creates inference pipelines, and handles optimization/V&V.",
  "module-code": "bmad-dl-lifecycle",
  "has-memory": true,
  "capabilities": [
    {
      "name": "techspec",
      "menu-code": "DLTS",
      "description": "Writes the pre-experiment contract (TECHSPEC).",
      "supports-headless": true,
      "phase-name": "4.5-techspec",
      "after": ["detailed-design"],
      "before": ["infra"],
      "is-required": true,
      "prompt": "techspec.md",
      "output-location": "{output_folder}/techspecs"
    },
    {
      "name": "infra",
      "menu-code": "DLINF",
      "description": "Builds data pipelines, training loops, and eval harness.",
      "supports-headless": true,
      "phase-name": "5-infra",
      "after": ["techspec"],
      "before": ["experiment"],
      "is-required": true,
      "prompt": "infra.md",
      "output-location": "{output_folder}/implementation"
    }
  ]
}
