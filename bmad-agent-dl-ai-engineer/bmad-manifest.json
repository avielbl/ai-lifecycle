{
  "name": "bmad-agent-dl-ai-engineer",
  "description": "Training Specialist. Executes experiments, training runs, and hyperparameter optimization. Outputs models and results.",
  "module-code": "bmad-dl-lifecycle",
  "has-memory": true,
  "capabilities": [
    {
      "name": "experiment",
      "menu-code": "DLEXP",
      "description": "Executes training runs against the TECHSPEC.",
      "supports-headless": true,
      "phase-name": "6-experiment",
      "after": ["infra"],
      "before": ["analysis"],
      "is-required": true,
      "prompt": "experiment.md",
      "output-location": "{output_folder}/experiments"
    },
    {
      "name": "hparam",
      "menu-code": "DLHPO",
      "description": "Runs hyperparameter optimization (Optuna/W&B/Ray/ClearML).",
      "supports-headless": true,
      "phase-name": "7.5-hparam",
      "after": ["analysis"],
      "before": ["experiment"],
      "is-required": false,
      "prompt": "hparam.md",
      "output-location": "{output_folder}/experiments"
    }
  ]
}
